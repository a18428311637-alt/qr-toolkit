{
  "name": "qr-toolkit",
  "version": "1.0.0",
  "description": "二维码生成与识别工具",
  "author": "a18428311637-alt",
  "repository": {
    "type": "git",
    "url": "https://github.com/a18428311637-alt/qr-toolkit.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "dist:portable": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.qr-toolkit.app",
    "productName": "QR Toolkit",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "a18428311637-alt",
      "repo": "qr-toolkit"
    },
    "compression": "maximum",
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}-${version}-Portable.${ext}"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "style.css",
      {
        "from": "node_modules",
        "to": "node_modules",
        "filter": [
          "**/*",
          "!**/README*",
          "!**/readme*",
          "!**/CHANGELOG*",
          "!**/changelog*",
          "!**/HISTORY*",
          "!**/LICENSE*",
          "!**/LICENCE*",
          "!**/*.md",
          "!**/*.markdown",
          "!**/*.ts",
          "!**/*.d.ts",
          "!**/*.map",
          "!**/test/**",
          "!**/tests/**",
          "!**/__tests__/**",
          "!**/spec/**",
          "!**/.eslintrc*",
          "!**/.prettierrc*",
          "!**/docs/**",
          "!**/examples/**",
          "!**/.github/**"
        ]
      }
    ]
  },
  "keywords": ["qrcode", "electron", "jsqr"],
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "qrcode": "^1.5.3",
    "jsqr": "^1.4.0"
  }
}