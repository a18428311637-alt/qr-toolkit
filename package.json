{
  "name": "qr-toolkit",
  "version": "1.0.0",
  "description": "二维码生成与识别工具",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.qr-toolkit.app",
    "productName": "QR Toolkit",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "style.css",
      "node_modules/**/*"
    ]
  },
  "keywords": ["qrcode", "electron", "jsqr"],
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "qrcode": "^1.5.3",
    "jsqr": "^1.4.0"
  }
}
