{
  "name": "qr-toolkit",
  "version": "1.0.0",
  "description": "二维码生成与识别工具",
  "author": "a18428311637-alt",
  "repository": {
    "type": "git",
    "url": "https://github.com/a18428311637-alt/qr-toolkit.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.qr-toolkit.app",
    "productName": "QR Toolkit",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "a18428311637-alt",
      "repo": "qr-toolkit"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "style.css",
      "node_modules/**/*"
    ]
  },
  "keywords": ["qrcode", "electron", "jsqr"],
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "qrcode": "^1.5.3",
    "jsqr": "^1.4.0"
  }
}